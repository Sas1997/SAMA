# MANIFEST.in — controls what goes into the SOURCE DISTRIBUTION (sdist / .tar.gz)
# The wheel (.whl) is controlled by package_data in pyproject.toml.
# Both must be consistent so pip install works whether from sdist or wheel.

# --- Package data files (inside samapy/) ---
recursive-include samapy/content *

# --- Top-level project files ---
include README.md
include License
include requirements.txt
include pyproject.toml

# --- Examples and tests (useful for developers who download the sdist) ---
recursive-include examples *.py *.csv *.yaml *.yml
recursive-include tests *.py

# --- Exclude things that should never be in a distribution ---
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.pyo
global-exclude .DS_Store
global-exclude Thumbs.db
prune dist
prune build
prune *.egg-info
